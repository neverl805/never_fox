# Python
__pycache__/
*.pyc
*.egg-info/

# Native build artifacts — regenerate with `bash native/build.sh` + `python native/bundle.py`
native/libfxtls.dylib
native/fxtls
native/*.dSYM/
native/vendor/

# neqo: large third-party clone + Rust build (~343MB). See README for HTTP/3 setup.
native/neqo/

# h3 build: native/h3/build_h3.py clones+builds these; the prebuilt binary is
# staged into the wheel by stage_lib.py. Keep the patched source files (native/h3/files/).
native/h3/build/
native/h3/neqo-client
native/h3/neqo-client.exe
native/h3/*.tgz

# Fingerprint capture artifacts (regenerable by the harness)
captures/
harness/localcap/*.json

# Throwaway local CA + browser profile — contain PRIVATE KEYS, never publish
harness/localcap/certs/
harness/localcap/ffprofile/

# macOS
.DS_Store
native/_verify_ch.json

# Wheel staging (regenerated by native/stage_lib.py) + build dirs
never_fox/_lib/
build/
dist/
*.egg-info/
dist2/
